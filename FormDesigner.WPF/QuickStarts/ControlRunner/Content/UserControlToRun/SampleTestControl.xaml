<UserControl 
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             Height="Auto" Width="Auto">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="10" CornerRadius="8" Background="#F3F4F6" BorderBrush="#D1D5DB" BorderThickness="1">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="Sample Test Control" FontSize="16" FontWeight="SemiBold"/>
                    <TextBlock Text="Standard WPF controls for UI testing." Foreground="#6B7280" Margin="0,3,0,0"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Width="90" Margin="0,0,8,0" Content="Action 1"/>
                    <Button Width="90" Content="Action 2"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Form -->
        <GroupBox Grid.Row="1" Header="Inputs" Margin="0,12,0,0">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="Name:"/>
                <TextBox   Grid.Row="0" Grid.Column="1" Height="26" Margin="0,0,0,6" Text="John Doe"/>

                <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="Age:"/>
                <TextBox   Grid.Row="1" Grid.Column="1" Height="26" Margin="0,0,0,6" Text="30"/>

                <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="Role:"/>
                <ComboBox  Grid.Row="2" Grid.Column="1" Height="26" Margin="0,0,0,6" SelectedIndex="0">
                    <ComboBoxItem Content="User"/>
                    <ComboBoxItem Content="Admin"/>
                    <ComboBoxItem Content="Guest"/>
                </ComboBox>

                <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Text="Date:"/>
                <DatePicker Grid.Row="3" Grid.Column="1" Margin="0,0,0,6"/>

                <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal">
                    <CheckBox Content="Enabled" IsChecked="True" Margin="0,0,12,0"/>
                    <RadioButton GroupName="mode" Content="Mode A" IsChecked="True" Margin="0,0,12,0"/>
                    <RadioButton GroupName="mode" Content="Mode B"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- Main content -->
        <Grid Grid.Row="2" Margin="0,12,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Grid.Column="0" Header="List">
                <DockPanel Margin="10">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock VerticalAlignment="Center" Text="Filter:"/>
                        <TextBox Width="160" Margin="8,0,0,0" Height="26" />
                        <Button Margin="8,0,0,0" Width="80" Content="Apply"/>
                    </StackPanel>

                    <ListView>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Id" Width="60"/>
                                <GridViewColumn Header="Title" Width="180"/>
                            </GridView>
                        </ListView.View>

                        <!-- Static sample rows -->
                        <ListViewItem>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Width="60" Text="1"/>
                                <TextBlock Width="180" Text="First item"/>
                            </StackPanel>
                        </ListViewItem>
                        <ListViewItem>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Width="60" Text="2"/>
                                <TextBlock Width="180" Text="Second item"/>
                            </StackPanel>
                        </ListViewItem>
                        <ListViewItem>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Width="60" Text="3"/>
                                <TextBlock Width="180" Text="Third item"/>
                            </StackPanel>
                        </ListViewItem>
                    </ListView>
                </DockPanel>
            </GroupBox>

            <GroupBox Grid.Column="2" Header="Text / Output">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Notes:"/>
                    <TextBox Grid.Row="1"
                             Margin="0,6,0,6"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Text="This is a multiline TextBox used for testing."/>
                    <ProgressBar Grid.Row="2" Height="16" Minimum="0" Maximum="100" Value="35"/>
                </Grid>
            </GroupBox>
        </Grid>

        <!-- Footer -->
        <DockPanel Grid.Row="3">
            <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center" Foreground="#6B7280"
                       Text="Status: Ready"/>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Width="90" Margin="0,0,8,0" Content="OK"/>
                <Button Width="90" Content="Cancel"/>
            </StackPanel>
        </DockPanel>

    </Grid>
</UserControl>