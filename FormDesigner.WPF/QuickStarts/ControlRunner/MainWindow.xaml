<Window x:Class="ControlRunner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ControlRunner"
        mc:Ignorable="d"
        Icon="Images/Icon.ico" 
        Title="Control Runner" Height="900" Width="700" WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="{x:Static ToolBar.ButtonStyleKey}"
           TargetType="{x:Type Button}"
           BasedOn="{StaticResource {x:Type Button}}"/>
    </Window.Resources>
    
    <DockPanel>

        <!-- Top toolbar -->
        <ToolBarTray DockPanel.Dock="Top">
            <ToolBar>
                <Button Content="Load Window"
                        Name="LoadWindowButton"
                        Margin="2"/>
                <Button Content="Load User Control"
                        Name="LoadUserControlButton"
                        Margin="2"/>
                <Button Content="Load..."
                        Name="LoadButton"
                        Margin="2"/>
                <Button Content="Design User Control"
                        Name="DesignButton"
                        IsEnabled="True"
                        Margin="2"/>
            </ToolBar>
        </ToolBarTray>

        <!-- Content area -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Auto"
                      Padding="12">

            <!-- This is the placeholder host. Replace its Content in code when you load a control -->
            <ContentControl x:Name="ContentHost">
                <Border Padding="24"
                        CornerRadius="8"
                        BorderThickness="1"
                        BorderBrush="#D1D5DB"
                        Background="#FAFAFA">
                    <TextBlock Text="UserControl will be here"
                               Foreground="#6B7280"
                               FontSize="16"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
            </ContentControl>

        </ScrollViewer>

    </DockPanel>
</Window>    